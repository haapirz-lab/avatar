# ── Akademia AI Avatar — backend environment ──────────────────────────────
# Copy this file to ".env" (same folder as backend.py) and fill in your key.

# 1) Use Groq (default). Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# Optional — pick any chat model your Groq account supports.
GROQ_MODEL=llama-3.3-70b-versatile

# Which provider to use: "groq" (default) or "openai".
LLM_PROVIDER=groq

# 2) (Optional) If you ever switch back to OpenAI, set LLM_PROVIDER=openai
#    and provide these instead:
# OPENAI_API_KEY=sk-your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini
